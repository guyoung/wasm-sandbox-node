{
  "name": "openclaw-wasm-sandbox",
  "version": "0.2.0",
  "description": "Wasm Sandbox Plugin for OpenClaw",
  "author": "guyoung",
  "homepage": "https://github.com/guyoung/wasm-sandbox-node/tree/main/openclaw",
  "repository": "https://github.com/guyoung/wasm-sandbox-node", 
